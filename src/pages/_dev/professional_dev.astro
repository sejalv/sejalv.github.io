---
// pages/professional.astro
import MainLayout from '../layouts/MainLayout.astro';
import BookshelfPanel from '../components/BookshelfPanel.astro';
import CareerSection from '../components/CareerSection.astro';

const careerData = await import('../data/career.md');
const careerHistory = careerData.frontmatter.careerHistory;
---

<MainLayout
    title="Professional"
    bannerImage='/assets/images/night-skyline.jpg'
    bannerTitle="Professional"
    showBanner={true}>
    <Fragment slot="description-sub-text">
        With 14+ years of Tech industry experience building scalable data platforms in Digital Health, FinTech and e-Commerce.
        Proven track record in reliable and high-impact data systems, embedding platform thinking within cross-functional teams, and shaping data strategies aligned with long-term business goals.

        Currently focused on Data Architecture and Platform Leadership, and designing modular infrastructure to enable analytics, ML, and product growth.
    </Fragment>

  <div id="main">
    <!-- Career Section Component -->
    <div class="inner">
      <CareerSection id="experience" title="Experience" gridColumns={3}>
        {careerHistory.map((job, idx) => (
          <article class="career-card" data-card-index={`career-${idx}`} data-controls={`career-dev-extra-${idx}`}>
            <div class="career-content">
              <h3>{job.company}</h3>
              <span class="date">{job.period}</span>
              <span class="date">{job.location}</span>
              <p class="job-title">{job.title}</p>
              <p>{job.description}</p>
            </div>
            {(job.highlights || job.technologies) && (
              <div id={`career-dev-extra-${idx}`} class="card-extra" hidden>
                {job.highlights && (
                  <div class="highlights">
                    <h4>Highlights</h4>
                    <ul>
                      {job.highlights.map((hl) => (
                        <li>{hl}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {job.technologies && (
                  <div class="technologies">
                    <h4>Technologies</h4>
                    <div class="tech-tags">
                      {job.technologies.map((tech) => (
                        <span class="tech-tag">{tech}</span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}
          </article>
        ))}
      </CareerSection>
    </div>

    <div class="sub-inner">
      <BookshelfPanel
        title="Bookshelf"
        maxBooks={1}
        showTitle={true}
      />
    </div>

    <!-- Future sections for actual writing content -->
        <!-- <section id="essays" class="inner">
          <header class="major">
            <h2>Blog</h2>
          </header>
          Add your essays/writing content here
        </section> -->
  </div>
</MainLayout>

<style>
  .card-extra {
    padding: 0 1.5em 1.25em 1.5em;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.career-card').forEach((card) => {
      card.addEventListener('click', function(event) {
        if (event.target.closest('a, button, .card-extra')) return;

        const controlsId = this.getAttribute('data-controls');
        const extra = controlsId ? document.getElementById(controlsId) : null;
        if (!extra) return;

        if (extra.hasAttribute('hidden')) {
          extra.removeAttribute('hidden');
        } else {
          extra.setAttribute('hidden', '');
        }
      });
    });
  });
  </script>