---
// layouts/MainLayout.astro
import ContactModal from '../components/ContactModal.astro';

export interface Props {
  title: string;
  description?: string;
  bannerImage?: string;
  bannerTitle?: string;
  bannerDescription?: string;
  showBanner?: boolean;
}

const {
  title,
  description,
  bannerImage,
  bannerTitle,
  bannerDescription,
  showBanner = true
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <noscript><link rel="stylesheet" href="/assets/css/noscript.css" /></noscript>
    <link rel="stylesheet" href="/assets/css/scroll-buttons.css" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
  </head>

  <body class="is-preload">
    <div id="wrapper">
      <!-- Header -->
      <header id="header" class={showBanner ? "alt" : ""}>
        <a href="/" class="logo"><strong>Sejal</strong> <span>Vaidya</span></a>
        <nav>
          <a href="#menu">Menu</a>
        </nav>
      </header>

      <!-- Menu -->
      <nav id="menu">
        <ul class="links">
          <li><a href="/">Home</a></li>
          <li><a href="/professional">Professional</a></li>
          <li><a href="/personal">Personal Notes</a></li>
          <li><a href="#about">About Me</a></li>
        </ul>
        <ul class="actions stacked">
          <li><a href="#" class="button primary fit contact-modal-trigger">Contact</a></li>
        </ul>
        <br/>
        <ul class="icons">
          <li><a href="https://www.linkedin.com/in/vaidyasejal/" class="icon brands alt fa-linkedin-in"><span class="label">LinkedIn</span></a></li>
          <li><a href="https://github.com/sejalv" class="icon brands alt fa-github"><span class="label">GitHub</span></a></li>
        </ul>
      </nav>

      {showBanner && (
        <section id="banner" class="major" style={`background-image: url(${bannerImage})`}>
          <div class="inner">
            <header class="major">
              <h1>{bannerTitle}</h1>
            </header>
            <div class="content">
              <p>{bannerDescription}</p>
            </div>
            <p class="description-sub-text">
              <slot name="description-sub-text" />
            </p>
          </div>
        </section>
      )}

      <!-- Main Content -->
      <div id="main">
        <slot />
      </div>

      <!-- About Section 
      Over 14 years, I've built scalable data platforms to empower organisations with decision-making systems and high-leverage tooling.
              </br></br>
              My goal is to make data a core product capability, not just a support function, by enabling teams to move faster, serve customers better, and make smarter decisions at scale.
      as a strategic asset
      
      I often write about platform engineering, systems thinking, FLINTA leadership, and life in Berlin.
      and cultural narratives that challenge dominant structures

       <div class="about-image">
              <img src="/assets/images/profile_sejal.jpg" alt="Sejal Vaidya" />
            </div>
      -->
      <section id="about" class="about-section" style="background-image: url('/assets/images/pic07.jpg');">
        <div class="inner">
          <div class="about-content">
            <div class="about-text">
              <header class="major">
                <h2>About Me</h2>
              </header>
              I am a Data & Engineering professional, who is drawn to problems where thoughtful platform design creates real impact. I live in Berlin, Germany. 
              </br></br>
              I am passionate about climate tech & sustainability, fostering an inclusive environment, and promoting gender diversity through community building. I write about tech, data, and culture.
              </br></br>
              If you are looking for a consultation on your data strategy, platform foundations, or a collaboration on a project, feel free to reach out here:
              </br></br>
              <div class="about-actions">
                <ul class="actions">
                  <li>
                    <a href="#contact-modal" class="button primary contact-modal-trigger">Contact</a>
                  </li>
                  <li>
                    <a href="https://www.linkedin.com/in/vaidyasejal/" target="_blank" rel="noopener noreferrer" class="button icon brands fa-linkedin-in">LinkedIn</a>
                  </li>
                </ul>
              </div>
            </div>
           
          </div>
        </div>
        <a href="#contact-modal" class="more scrolly contact-modal-trigger"></a>
      </section>

      <!-- Contact Modal -->
      <ContactModal />

      <!-- Footer -->
      <footer id="footer">
        <div class="inner">
          <ul class="copyright">
            <li>&copy; Sejal Vaidya</li>
            <li>All rights reserved.</li>
          </ul>
        </div>
      </footer>
    </div>

    <!-- Scripts -->
    <script is:inline src="/assets/js/jquery.min.js"></script>
    <script is:inline src="/assets/js/jquery.scrolly.min.js"></script>
    <script is:inline src="/assets/js/jquery.scrollex.min.js"></script>
    <script is:inline src="/assets/js/browser.min.js"></script>
    <script is:inline src="/assets/js/breakpoints.min.js"></script>
    <script is:inline src="/assets/js/util.js"></script>
    <script is:inline src="/assets/js/main.js"></script>
    <script is:inline src="/assets/js/smooth-scroll.js"></script>

    <style>
      .description-sub-text {
          white-space: pre-line;
      }

      /* About section styles */
      .about-section {
        margin-top: 0;
        position: relative;
      }

      .about-content {
        display: flex;
        align-items: center;
        gap: 2rem;
        max-width: 100%;
      }

      .about-text {
        flex: 1;
        text-align: left;
        font-size: 1.1rem;
        font-weight: 400;
      }

      .about-image {
        flex-shrink: 0;
        width: 350px;
        height: 400px;
        border-radius: 8px;
        overflow: hidden;
        border: none;
      }

      .about-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 70% !important;
      }

      .about-actions {
        margin-top: 1rem;
      }

      /* Tablet responsiveness for About section */
      @media screen and (max-width: 980px) {
        .about-section {
          height: 30vh !important;
        }

        .about-section .inner {
          max-width: 80%;
          padding: 1rem 1rem;
        }
      }

      /* Mobile responsiveness for About section */
      @media screen and (max-width: 736px) {
        .about-section {
          height: auto !important;
          min-height: 60vh !important;
          padding: 0;
        }

        .about-section .inner {
          max-width: 90%;
          padding: 3rem 1.5rem;
        }
      }

      /* Footer height reduction */
      #footer .inner {
        padding: 1em 0 0.5em 0 !important;
      }

      @media screen and (max-width: 736px) {
        #footer .inner {
          padding: 1em 0 0.5em 0 !important;
        }
      }
    </style>
  </body>
</html>
