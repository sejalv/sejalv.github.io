---
// components/CareerSection.astro

export interface Props {
  id?: string;
  title?: string;
  showTitle?: boolean;
  gridColumns?: number;
  items?: Array<{
    company: string;
    period?: string;
    location?: string;
    title?: string;
    description?: string;
    highlights?: string[];
    technologies?: string[];
  }>;
}

const {
  id = "career-section",
  title = "Experience",
  showTitle = true,
  gridColumns = 4,
  items = []
} = Astro.props;
---

<section id={id} class="career-section">
  {showTitle && (
    <header class="major">
      <h2>{title}</h2>
    </header>
  )}

  <div class="career-grid" style={`--career-columns: ${gridColumns};`}>
    <slot />
  </div>
</section>

<style>
  .career-section {
   margin: -0.5em 0 -1.5em 0;
  }

  .career-grid {
    display: grid;
    gap: 2em;
    margin: 2em 0;
    grid-template-columns: repeat(var(--career-columns, 4), 1fr);
  }

  :global(.career-card) {
    background: rgba(0, 0, 0, 0.06);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
    position: relative;
  }

  :global(.career-card:hover) {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  :global(.career-content) {
    padding: 1.5em;
  }

  :global(.career-content h3) {
    margin-bottom: 0.5em;
    font-size: 1.2em;
  }

  :global(.date) {
    display: block;
    font-size: 0.8em;
    font-weight: bold;
    color: rgba(212, 212, 255, 0.5);
    margin-bottom: 1em;
  }

  :global(.job-title) {
    font-size: 0.85em;
    font-weight: bold;
    color: rgba(212, 212, 255, 0.5);
    margin-bottom: 1em;
  }

  /* Expanded details */
  :global(.card-extra) {
    padding: 0 1.5em 1.25em 1.5em;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.card-extra .highlights h4),
  :global(.card-extra .technologies h4) {
    font-size: 0.95em;
    margin: 0.75em 0 0.5em 0;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.card-extra .highlights ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  :global(.card-extra .highlights li) {
    font-size: 0.8em;
    margin: 0.25em 0;
    color: rgba(255, 255, 255, 0.8);
    position: relative;
    padding-left: 1em;
  }

  :global(.card-extra .highlights li::before) {
    content: "•";
    color: #87c5a4;
    position: absolute;
    left: 0;
  }

  :global(.card-extra .tech-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35em;
  }

  :global(.card-extra .tech-tag) {
    background: rgba(135, 197, 164, 0.2);
    color: #87c5a4;
    padding: 0.25em 0.6em;
    border-radius: 10px;
    font-size: 0.75em;
    border: 1px solid rgba(135, 197, 164, 0.3);
  }

  :global(.career-card:hover .card-overlay) {
    opacity: 1;
  }

  :global(.card-overlay) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(135, 197, 164, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  :global(.view-details) {
    color: white;
    font-weight: bold;
    font-size: 1.1em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  :global(.description) {
    font-size: 0.87em;
    line-height: 1.4;
    margin-bottom: 1em;
    color: rgba(255, 255, 255, 0.8);
  }

  :global(.highlights) {
    margin: 1em 0;
  }

  :global(.highlights h4) {
    font-size: 0.9em;
    margin-bottom: 0.5em;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.highlights ul) {
    list-style: none;
    padding-left: 0;
  }

  :global(.highlights li) {
    font-size: 0.8em;
    line-height: 1.3;
    margin-bottom: 0.3em;
    color: rgba(255, 255, 255, 0.7);
    position: relative;
    padding-left: 1em;
  }

  :global(.highlights li::before) {
    content: "•";
    color: #87c5a4;
    position: absolute;
    left: 0;
  }

  :global(.technologies) {
    margin-top: 1em;
  }

  :global(.technologies h4) {
    font-size: 0.9em;
    margin-bottom: 0.5em;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.tech-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3em;
  }

  :global(.tech-tag) {
    background: rgba(135, 197, 164, 0.2);
    color: #87c5a4;
    padding: 0.2em 0.5em;
    border-radius: 3px;
    font-size: 0.5em;
    border: 1px solid rgba(135, 197, 164, 0.3);
  }

  /* Modal Content Styles */
  :global(.career-modal-content) {
    color: #ffffff;
  }

  :global(.modal-header-info) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.modal-period) {
    font-weight: bold;
    color: #87c5a4;
  }

  :global(.modal-location) {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9em;
  }

  :global(.modal-description) {
    margin-bottom: 2rem;
  }

  :global(.modal-description p) {
    font-size: 1.1em;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.modal-highlights) {
    margin-bottom: 2rem;
  }

  :global(.modal-highlights h4) {
    color: #87c5a4;
    margin-bottom: 1rem;
    font-size: 1.1em;
  }

  :global(.modal-highlights ul) {
    list-style: none;
    padding: 0;
  }

  :global(.modal-highlights li) {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
  }

  :global(.modal-highlights li::before) {
    content: "▸";
    position: absolute;
    left: 0;
    color: #87c5a4;
    font-weight: bold;
  }

  :global(.modal-technologies h4) {
    color: #87c5a4;
    margin-bottom: 1rem;
    font-size: 1.1em;
  }

  :global(.tech-tags .tech-tag) {
    background: rgba(135, 197, 164, 0.2);
    color: #87c5a4;
    padding: 0.4em 0.8em;
    border-radius: 12px;
    font-size: 0.7em;
    font-weight: 500;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .career-grid {
      grid-template-columns: 1fr;
    }

    :global(.career-card) {
      flex-direction: column;
    }

    :global(.career-header) {
      flex-direction: column;
      align-items: flex-start;
    }

    :global(.period) {
      margin-top: 0.5em;
    }

    :global(.modal-header-info) {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>

<script>
/*
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.career-card').forEach((card) => {
      card.addEventListener('click', function(event) {
        // Don't toggle when clicking interactive elements or the expanded area itself
        if (event.target.closest('a, button, .card-extra')) return;

        const controlsId = this.getAttribute('data-controls');
        const extra = controlsId ? document.getElementById(controlsId) : null;
        if (!extra) return;

        if (extra.hasAttribute('hidden')) {
          extra.removeAttribute('hidden');
        } else {
          extra.setAttribute('hidden', '');
        }
      });
    });
  });
  */
</script>



